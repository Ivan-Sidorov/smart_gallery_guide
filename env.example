# ============================================================================
# Telegram
# ============================================================================
TELEGRAM_BOT_TOKEN=<YOUR_TG_BOT_TOKEN>

# ============================================================================
# ChromaDB (persistent vector store)
# ============================================================================
# Directory where ChromaDB persists collections and BM25 sidecar indices.
CHROMA_PERSIST_DIR=./chroma_store

# Collection names. Defaults should be fine for single-tenant setups.
CHROMA_COLLECTION_EXHIBITS=exhibits
CHROMA_COLLECTION_TITLE=exhibits_title
CHROMA_COLLECTION_DESC=exhibits_desc
CHROMA_COLLECTION_FAQ=faq

# ============================================================================
# vLLM (OpenAI-compatible VLM server)
# ============================================================================
VLLM_API_BASE_URL=http://localhost:8000/v1
VLLM_VLM_MODEL=Qwen/Qwen3-VL-8B-Instruct
VLLM_VLM_MAX_TOKENS=500
VLLM_VLM_TEMPERATURE=0.7
# For reasoning-capable models (e.g. Qwen3): pass enable_thinking=false via extra_body.
VLLM_VLM_DISABLE_THINKING=true
VLLM_API_KEY=<YOUR_VLLM_API_KEY>

# ============================================================================
# Encoder models (HuggingFace identifiers)
# ============================================================================
VISION_ENCODER_MODEL=google/siglip-base-patch16-224
TEXT_ENCODER_MODEL=deepvk/USER-bge-m3
ASR_ENCODER_MODEL=openai/whisper-small
# Leave empty to auto-detect.
ASR_ENCODER_LANGUAGE=russian

# ============================================================================
# Retrieval thresholds
# ============================================================================
# Minimum cosine score for a result to be considered a confident match.
EXHIBIT_MATCH_THRESHOLD=0.6
# Minimum cosine score for an FAQ answer to be returned instead of VLM fallback.
FAQ_RELEVANCE_THRESHOLD=0.6
# Minimum cosine score for a result to be surfaced to the user at all.
DISPLAY_SCORE_THRESHOLD=0.5

# ============================================================================
# Web search (used by VLM to enrich answers when local context is insufficient)
# ============================================================================
WEB_SEARCH_ENABLED=true
WEB_SEARCH_MAX_RESULTS=5

# ============================================================================
# PostgreSQL
# ============================================================================
DATABASE_URL=postgresql+asyncpg://smart_guide:smart_guide@localhost:5432/smart_guide
DATABASE_ECHO=false
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# ============================================================================
# FastAPI backend
# ============================================================================
API_HOST=0.0.0.0
API_PORT=8081
API_LOG_LEVEL=info
API_REQUEST_ID_HEADER=X-Request-Id
# API_LOAD_ML=false in tests to skip TextEncoder + Chroma loading.
API_LOAD_ML=true
API_DEFAULT_TOP_K=5
API_MAX_TOP_K=20

# ============================================================================
# Telegram adapter
# ============================================================================
# Base URL of the FastAPI backend the adapter calls over HTTP
ADAPTER_BACKEND_URL=http://localhost:8081
# Default HTTP timeout (seconds) for adapter -> API calls
ADAPTER_HTTP_TIMEOUT_S=30.0
# Polling /v1/tasks/{id} for VLM completion
ADAPTER_TASK_POLL_INITIAL_S=0.5
ADAPTER_TASK_POLL_MAX_S=3.0
ADAPTER_TASK_POLL_FACTOR=1.5
# Total time budget for waiting on a VLM task before giving up
ADAPTER_TASK_POLL_TIMEOUT_S=120.0
# Header used to propagate request-id from adapter to the API
ADAPTER_REQUEST_ID_HEADER=X-Request-Id
ADAPTER_LOG_LEVEL=info

# ============================================================================
# VLM worker
# ============================================================================
# How often the worker polls inference_tasks when the queue is empty.
WORKER_POLL_INTERVAL_S=1.0
# Max number of VLM tasks one worker handles concurrently.
WORKER_CONCURRENCY=2
# Running tasks older than this are re-queued by the recovery sweep.
WORKER_STALE_TIMEOUT_S=300
# How often the recovery sweep runs.
WORKER_STALE_CHECK_INTERVAL_S=60
